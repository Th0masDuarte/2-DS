package exercicio15;

import java.util.Scanner;

public class Exercicio15 {
    public static void main(String[] args) {       
        Scanner teclado=new Scanner(System.in);
        String par="";
        String impar="";
        int contpar=0;
        int contimpar=0;
        for(int i =0;i<10;i++){
            int numero=teclado.nextInt();
            if(numero%2==0){
              par+=numero+" ";
              contpar++;
            }else{
                impar+=numero+" ";
                contimpar++;
            }
        }
        System.out.println("Total de "+contpar+" Pares: "+par);
        System.out.println("Total de "+contimpar+" Impares: "+impar);
    }
    
}

