        int tamanho=teclado.nextInt();
        System.out.println();
        for (int i=1;i<=tamanho;i++){
            for(int a=1;a<=i;a++){
                System.out.print("*");
            }
        
            System.out.println();
        }
            for (int j=tamanho;j>=1;j--){
            for(int b=1;b<=j;b++){
