package exercicio14.calculadora.de.imc.com.faixa;

import javax.swing.JOptionPane;
import static javax.swing.JOptionPane.showMessageDialog;

public class Exercicio14CalculadoraDeIMCComFaixa {

    public static void main(String[] args) {
        String peso= JOptionPane.showInputDialog("Digite seu peso(ex:70): ");   
        String altura= JOptionPane.showInputDialog("Digite sua altura(ex:1.75): ");   
        double peso1=Double.parseDouble(peso);
        double altura1=Double.parseDouble(altura);
        double imc=peso1/(altura1*altura1);
        String imcFormatado=String.format("%.2f", imc);
        if(imc < 18.5){
        showMessageDialog(null,"Você está ABAIXO DO PESO, pois seu IMC é: "+imcFormatado);
        } else if(imc < 25.00){
        showMessageDialog(null,"Você está NORMAL, pois seu IMC é: "+imcFormatado);
        } else if(imc < 30.00){
        showMessageDialog(null,"Você está com SOBREPESO, pois seu IMC é: "+imcFormatado);
        } else {
        showMessageDialog(null,"Você está com OBESIDADE, pois seu IMC é: "+imcFormatado);
        }
}
}
