@startuml
left to right direction

actor Cliente
actor "Atendente de Logística" as Atendente

rectangle "Sistema TechStore" {

  usecase "Realizar Login" as UC_Login
  usecase "Finalizar Compra" as UC_Compra
  usecase "Consultar Status do Pedido" as UC_Status
  usecase "Atualizar Rastreamento" as UC_Rastreamento

  Cliente --> UC_Compra
  Cliente --> UC_Status

  Atendente --> UC_Rastreamento

  UC_Compra ..> UC_Login : <<include>>
  UC_Status ..> UC_Login : <<include>>
  UC_Rastreamento ..> UC_Login : <<include>>
}

@enduml
